POSTGRES_USER=cosmix
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=cosmix
DATABASE_URL=postgres://cosmix:replace-with-a-strong-password@postgres:5432/cosmix

# Optional only if Strava sync is needed in deployment.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Must match the Authorization Callback Domain / redirect URI in Strava app settings.
STRAVA_REDIRECT_URI=http://YOUR_HOST:3004/wellness/strava/callback
# Where Strava OAuth should send the user after connect (web app origin).
WEB_APP_URL=http://YOUR_HOST:3005
