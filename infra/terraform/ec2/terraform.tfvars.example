aws_region      = "us-east-1"
availability_zone = "us-east-1a"
instance_type   = "t3.micro"
key_pair_name   = "your-ec2-keypair"
admin_cidr      = "0.0.0.0/0"
root_volume_size_gb = 12
swap_size_mb    = 2048

# Use a public repository URL here, or leave repo_url empty and copy the repo manually.
repo_url        = ""
repo_branch     = "main"